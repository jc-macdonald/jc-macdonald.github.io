{% assign repo_url = include.repository | split: '/' %}
{% if site.data.repositories.github_users contains repo_url.first %}
  {% assign show_owner = false %}
{% else %}
  {% assign show_owner = true %}
{% endif %}

{% comment %} Static HTML repo cards — no external service dependency {% endcomment %}
<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.repository }}" class="repo-card-link" style="text-decoration: none;">
    <div class="card hoverable" style="border: 1px solid var(--global-divider-color); border-radius: 6px; padding: 16px; text-align: left;">
      <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
        <i class="fa-brands fa-github" style="font-size: 1.1rem; color: var(--global-text-color);"></i>
        <span style="font-weight: 600; color: var(--global-theme-color); font-size: 0.95rem;">
          {% if show_owner %}{{ include.repository }}{% else %}{{ repo_url[1] }}{% endif %}
        </span>
      </div>
      {% assign repo_desc = site.data.repositories.repo_descriptions[include.repository] %}
      {% if repo_desc %}
        <p style="font-size: 0.85rem; color: var(--global-text-color-light); margin: 0; line-height: 1.4;">{{ repo_desc }}</p>
      {% endif %}
    </div>
  </a>
</div>
